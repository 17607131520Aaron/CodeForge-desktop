{
  "name": "codeforge-desktop",
  "productName": "AI助理调试工具",
  "version": "1.0.2",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:mac:arm64": "electron-forge make --platform=darwin --arch=arm64",
    "make:mac:x64": "electron-forge make --platform=darwin --arch=x64",
    "make:win:x64": "electron-forge make --platform=win32 --arch=x64",
    "make:desktop:all": "pnpm make:mac:arm64 && pnpm make:mac:x64 && pnpm make:win:x64",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "app:meta": "python3 -B scripts/update_app_meta.py",
    "release:mac": "pnpm app:meta && CSC_IDENTITY_AUTO_DISCOVERY=false pnpm make:mac:arm64 && CSC_IDENTITY_AUTO_DISCOVERY=false pnpm make:mac:x64",
    "fix:mac:damaged": "bash scripts/fix_macos_quarantine.command"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/17607131520Aaron/CodeForge-desktop.git"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.8",
    "@types/react-virtualized": "^9.22.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "39.2.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "typescript": "~5.9.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@types/ws": "^8.18.1",
    "@uidotdev/usehooks": "^2.4.1",
    "ahooks": "^3.9.6",
    "antd": "^6.2.0",
    "axios": "^1.13.2",
    "dayjs": "^1.11.19",
    "dexie": "^4.2.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.5",
    "electron-squirrel-startup": "^1.0.1",
    "js-cookie": "^3.0.5",
    "postcss-split": "^0.0.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.3",
    "react-query": "^3.39.3",
    "react-router-dom": "^7.12.0",
    "react-virtualized": "^9.22.6",
    "sass": "^1.97.2",
    "semver": "^7.7.3",
    "socket.io-client": "^4.8.3",
    "update-electron-app": "^3.1.2",
    "ws": "^8.19.0",
    "zustand": "^5.0.10"
  }
}
